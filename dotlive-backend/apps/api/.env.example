# =============================================================================
# DOT API — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development or set these in your Render
# dashboard for production. NEVER commit the actual `.env`.
# =============================================================================

# ── Core (required) ──────────────────────────────────────────────────────────

# Neon Postgres connection string (pooled URL, NOT direct).
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXX.us-east-2.aws.neon.tech/dotlive?sslmode=require"

# Random 64+ char hex for JWT signing. In Render, set this to generateValue:true
# or set manually: `openssl rand -hex 64`
JWT_SECRET="REPLACE_ME_WITH_64_CHARS_OF_RANDOM_HEX"

NODE_ENV=production
PORT=3001

# Public base URL where the API is reachable. Used for OAuth redirect URIs.
API_BASE_URL="https://dotlive-api.onrender.com"

# Frontend URL — used for password reset emails + OAuth post-callback redirects.
FRONTEND_URL="https://dotlive.cv"

# Comma-separated list of additional CORS origins. Hardcoded list already
# covers dotlive.cv + *.vercel.app + localhost.
ALLOWED_ORIGINS="https://dotlive-web.vercel.app,https://dotlive-lake.vercel.app"

# ── Google OAuth (optional but recommended) ──────────────────────────────────
# Get these from console.cloud.google.com → APIs & Services → Credentials.
# Authorized JavaScript origins: https://dotlive.cv
# Authorized redirect URIs:  https://dotlive-api.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (Resend — optional) ────────────────────────────────────────────────
# Get from resend.com → API Keys. Without this, password-reset emails are
# logged to stdout but not actually sent.
RESEND_API_KEY=""
# Default sender (must be a verified domain on Resend).
EMAIL_FROM="DOT OS <noreply@dotlive.cv>"

# ── Paystack (optional — for wallet top-ups) ─────────────────────────────────
# Get from paystack.com → Settings → API Keys.
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# ── Cloudinary (optional — for avatar / document uploads) ────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Whop (optional — for course revenue) ─────────────────────────────────────
WHOP_API_KEY=""
WHOP_WEBHOOK_SECRET=""

# ── Feature flags ────────────────────────────────────────────────────────────
# Anything set to "true" enables a feature; unset / "false" disables it.
FEATURE_FLAG_AI_ADVISOR="true"
FEATURE_FLAG_DOT_DEMO_REGISTRATION="true"
FEATURE_FLAG_COMMUNITY_BILLING="false"

# =============================================================================
# After changing this file, restart your local server:
#   pkill -f "node dist/server" && npm run dev
#
# In production, push the change and let Render auto-redeploy, or click
# "Manual Deploy" in the Render dashboard.
# =============================================================================
