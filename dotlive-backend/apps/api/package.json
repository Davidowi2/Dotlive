{
  "name": "@dotlive/api",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json || true",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/seed.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:500dot": "tsx src/db/migrations/credit-500-dot.ts",
    "cron:auto-release": "tsx src/scripts/auto-release-orders.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/oauth2": "^7.8.1",
    "@fastify/rate-limit": "9.1.0",
    "@fastify/websocket": "^11.3.0",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@neondatabase/serverless": "^0.9.4",
    "argon2": "^0.41.1",
    "cloudinary": "^2.4.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "lucia": "^3.2.2",
    "otplib": "^13.4.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/pg": "^8.11.6",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.24.2",
    "pg": "^8.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.10"
  }
}
