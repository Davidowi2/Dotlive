# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DOT — Africa's Venture Progression Network
# Environment Variables — copy to .env and fill in values
# NEVER commit .env to git — it is already in .gitignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Fastify API ───────────────────────────────────────────
# The URL of your deployed Fastify backend
VITE_API_URL=https://your-api.onrender.com

# ── Supabase (Client-side) ────────────────────────────────
# Exposed to the browser via Vite's import.meta.env
# Safe to expose — these are the anon/publishable keys only

# Your Supabase project URL (found in: Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/publishable key (NOT the service role key)
# Found in: Project Settings → API → Project API keys → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_SUPABASE_PUBLISHABLE_KEY

# ── Supabase (Server-side / SSR) ──────────────────────────
# Used in server functions (src/integrations/supabase/auth-middleware.ts)
# and the admin client (src/integrations/supabase/client.server.ts)
# These are NOT prefixed with VITE_ — never exposed to the browser

# Same project URL as above (duplicated for server context)
SUPABASE_URL=https://your-project.supabase.co

# Same anon key as above (used by auth-middleware to verify JWTs)
SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_SUPABASE_PUBLISHABLE_KEY

# ⚠️  SERVICE ROLE KEY — CRITICAL SECRET ⚠️
# Bypasses Row Level Security — grants full database access
# Used ONLY in server-side admin client (supabaseAdmin)
# Found in: Project Settings → API → Project API keys → service_role
# NEVER expose this to the client / browser / frontend code
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Paystack ──────────────────────────────────────────────
# Secret key for payment processing (server-side only)
# Found in: Paystack Dashboard → Settings → API Keys & Webhooks
# ⚠️  Never expose to the browser — server functions only
PAYSTACK_SECRET_KEY=REPLACE_WITH_YOUR_PAYSTACK_SECRET_KEY

# For local development / testing, use your test key:
# PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# ── Whop (optional) ───────────────────────────────────────
# If you use Whop API for course management beyond URL redirects
# Found in: Whop Dashboard → Developer → API Keys
# WHOP_API_KEY=whop_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SETUP CHECKLIST
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all values above
# 3. Run:             npm install
# 4. Run migrations:  npx supabase db push
# 5. Start dev:       npm run dev
#
# For Lovable Cloud deployment, set these as environment
# variables in your Lovable project settings — do NOT commit .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
