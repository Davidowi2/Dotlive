{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --workspace apps/web run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install --workspaces --include-workspace-root",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/$1"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "VITE_API_URL": "https://dotlive-api.onrender.com",
    "VITE_CLOUDINARY_CLOUD_NAME": "dccqvg23z"
  }
}
