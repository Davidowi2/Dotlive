# Neon Postgres (pooler for serverless, direct for migrations)
DATABASE_URL=postgresql://neondb_owner:***@ep-dry-star-a7g87iyp-pooler.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-32-byte-random-string-9f3a

# Cloudinary
CLOUDINARY_CLOUD_NAME=dccqvg23z
CLOUDINARY_API_KEY=722248122585694
CLOUDINARY_API_SECRET=replace-with-real-secret

# Google OAuth (from console.cloud.google.com)
